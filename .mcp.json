{
  "$schema": "https://modelcontextprotocol.io/schema/mcp.json",
  "version": "1.0.0",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub API integration - issues, PRs, repos. ⚠️ 项目级 npx 例外（上游 MCP 包无 Bun 入口）",
      "enabled": true,
      "timeout": 30000,
      "tools": [
        "create_issue",
        "create_pull_request",
        "list_issues",
        "search_repositories",
        "get_file_contents",
        "create_or_update_file"
      ]
    },

    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation for UI testing - test dashboard. ⚠️ 项目级 npx 例外（上游 MCP 包无 Bun 入口）",
      "enabled": true,
      "timeout": 120000,
      "tools": [
        "navigate",
        "screenshot",
        "click",
        "fill",
        "evaluate"
      ],
      "config": {
        "headless": true,
        "slowMo": 0,
        "defaultTimeout": 30000
      }
    },

    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "File system access. ⚠️ 项目级 npx 例外（上游 MCP 包无 Bun 入口），仅授予只读",
      "enabled": true,
      "timeout": 10000,
      "tools": [
        "read_file",
        "read_text_file",
        "list_directory",
        "directory_tree",
        "search_files"
      ]
    }
  },

  "globalConfig": {
    "maxConcurrentConnections": 5,
    "retryAttempts": 3,
    "retryDelay": 1000,
    "loggingLevel": "INFO",
    "cacheEnabled": true,
    "cacheTTL": 300
  },

  "security": {
    "validateSSL": true,
    "allowUntrustedCertificates": false,
    "encryptSecrets": true
  },

  "monitoring": {
    "enabled": true,
    "metrics": {
      "requestCount": true,
      "responseTime": true,
      "errorRate": true
    },
    "alerts": {
      "onError": true,
      "onSlowResponse": true,
      "threshold": 5000
    }
  },

  "project": {
    "name": "签单业绩分析看板",
    "type": "api-only-data-platform",
    "tech_stack": ["React", "TypeScript", "Express", "@duckdb/node-api (DuckDB native)", "Tailwind", "Bun"],
    "description": "Insurance data analysis platform: React client + Express REST API + DuckDB native backend. No DuckDB-WASM browser runtime."
  }
}
