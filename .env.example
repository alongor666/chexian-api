# 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值
# ⚠️ .env.local 已被 .gitignore 忽略，不会提交到 Git
#
# 所有环境变量均在 server/src/config/env.ts 中集中定义和分组管理。
# 修改/新增环境变量时，必须同步更新 env.ts。

# ============================================================
# 服务器配置 (serverEnv)
# ============================================================

# HTTP 监听端口（默认：3000）
PORT=3000

# 绑定主机（默认：127.0.0.1，仅本地回环；0.0.0.0 为所有网卡）
BIND_HOST=127.0.0.1

# ============================================================
# 认证配置 (authEnv)
# ============================================================

# JWT 签名密钥（生产环境必填，禁止使用默认占位符）
# 建议：openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Access Token 过期时间（默认：4h，支持 s/m/h/d 后缀）
JWT_EXPIRES_IN=4h

# Refresh Token 过期时间（默认：7d）
JWT_REFRESH_EXPIRES_IN=7d

# 用户密码覆盖（可选，JSON 格式，优先级高于默认哈希）
# 格式：{"admin":"$2b$10$...","leshan":"$2b$10$..."}
USER_PASSWORDS=

# 用户 IP 白名单覆盖（可选，JSON 格式）
# 格式：{"admin":["1.2.3.4","10.0.0.0/8"]}
USER_ALLOWED_IPS=

# 开发环境跳过认证（仅 NODE_ENV=development 时生效，值为 '1' 时启用）
DEV_SKIP_AUTH=

# ============================================================
# 数据库配置 (dbEnv)
# ============================================================

# DuckDB 数据库路径（:memory: = 内存，或指定文件路径）
DUCKDB_PATH=:memory:

# Parquet 数据文件目录（服务器运行时加载的数据位置）
DATA_PATH=./data

# DuckDB 最大内存用量。生产 VPS 4核4G 但内存 available 仅 ~1.9G 是瓶颈（非 CPU），
# 生产建议保守设 1.5GB 防 OOM；下方 4GB 为本地开发默认（开发机内存充裕）。
DUCKDB_MAX_MEMORY=4GB

# DuckDB 并发线程数。生产受内存瓶颈建议设 2（与 1.5GB 内存匹配）；下方 4 为本地开发默认。
DUCKDB_THREADS=4

# 数据版本标识，返回到 API 响应 meta 中（默认：v1）
DATA_VERSION=v1

# 是否启用 Bundle 路由（'false' 禁用，其他值均启用，默认启用）
ENABLE_QUERY_BUNDLES=true

# ============================================================
# AI 提供商配置 (aiEnv)
# ============================================================

# ------------------------------------------------------------
# OpenRouter（机构趋势 AI 主路由）
# 获取地址：https://openrouter.ai/keys
# AI_PRIMARY_MODEL 支持多个模型逗号分隔，按顺序自动降级
# 示例：AI_PRIMARY_MODEL=minimax/minimax-m2.5,openai/gpt-4o-mini
# ------------------------------------------------------------
OPENROUTER_API_KEY=
AI_PRIMARY_MODEL=minimax/minimax-m2.5

# 单模型请求超时（毫秒，默认：4500）
AI_PROVIDER_TIMEOUT_MS=4500

# 机构趋势解读缓存时长（毫秒，默认：180000 = 3分钟）
AI_TREND_CACHE_TTL_MS=180000

# ------------------------------------------------------------
# 智谱 GLM（推荐 - 中文优化，性价比高）
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
# 格式：{id}.{secret}（32字符.24字符）
# 用于：AI SQL 生成 + OpenRouter 降级兜底
# ------------------------------------------------------------
ZHIPU_API_KEY=

# ------------------------------------------------------------
# 未匹配意图飞书 Webhook 通知（可选）
# 不配置则静默忽略，不影响功能
# ------------------------------------------------------------
UNMATCHED_NOTIFY_WEBHOOK=

# ============================================================
# CORS 跨域配置 (corsEnv)
# ============================================================

# 允许的跨域来源（逗号分隔）
# 生产环境必填：CORS_ORIGIN=https://chexian.cretvalu.com
# 开发环境可留空（自动补充 localhost:5173-5176）
CORS_ORIGIN=

# ============================================================
# 飞书配置 (feishuEnv)（可选，不使用飞书扫码登录可留空）
# ============================================================

# 飞书应用 App ID（飞书开放平台 → 应用凭证）
FEISHU_APP_ID=

# 飞书应用 App Secret
FEISHU_APP_SECRET=

# 授权组织的飞书租户 key（组织门禁必填：未配置或不匹配一律拒绝登录）
# 取值：飞书管理后台可查，或看首次登录被拒时服务端日志里的 tenant_key
FEISHU_TENANT_KEY=

# 管理员飞书标识列表（逗号分隔，可填 user_id / open_id / 手机号 / 邮箱；
# 仅作 bootstrap，分层授权就绪后建议清空、统一走角色映射文件）
FEISHU_ADMIN_USERIDS=

# 飞书角色映射文件路径（用户→角色/机构分层授权；默认 server/data/feishu_role_mapping.json）
# FEISHU_ROLE_MAPPING_PATH=

# 飞书登录用户分公司编码覆盖（可选；留空跟随部署省份 BRANCH_CODE。
# 角色映射文件条目可用 branchCode 字段按人覆盖此全局值）
FEISHU_DEFAULT_BRANCH=

# 业务员映射表兜底开关（第 3 层：按飞书姓名匹配自动发 org_user）。
# 默认关闭（不在角色映射/管理员白名单 = 拒绝登录）；姓名重名有误授权风险，显式 true 才启用
FEISHU_SALESMAN_FALLBACK=

# 飞书部门个人账号灰度开关（仅 true 启用；默认关闭）
FEISHU_DEPARTMENT_PERSONAL_ACCOUNTS_ENABLED=

# 飞书部门授权配置文件路径（部门 → 机构/省份授权；默认 server/data/feishu_department_entitlements.json）
# 缺文件时回退代码内置默认表，行为与不下发一致；文件存在即整体接管。
# 种子模板见 server/src/config/feishu_department_entitlements.example.json
# FEISHU_DEPARTMENT_ENTITLEMENTS_PATH=

# ============================================================
# 运维配置 (opsEnv)
# ============================================================

# 审计日志文件路径（默认：logs/audit.log）
AUDIT_LOG_PATH=

# ============================================================
# 前端专用配置（VITE_ 前缀，仅构建时注入，不读取到后端）
# ============================================================

# 应用标题
VITE_APP_TITLE=车险业绩分析系统

# 是否启用预加载数据
VITE_AUTO_LOAD_DATA=false

# 预加载数据的 URL 路径
VITE_DATA_URL=/data/data.parquet

# 综合分析页开关（默认关闭，灰度开启）
VITE_ENABLE_COMPREHENSIVE_ANALYSIS=false

# 功能需求提交链接（显示在前端"无匹配"提示中）
VITE_FEATURE_REQUEST_URL=

# 智谱 API Key（前端直调场景，通常与后端共用同一 Key）
VITE_ZHIPU_API_KEY=
VITE_ZHIPU_MODEL=glm-4.7-flashx

# ============================================================
# 企业微信智能表格集成（post-ETL 自动推送，daily.mjs 步骤 8）
# ============================================================
# 本模块仅由 数据管理/daily.mjs 启动时从 .env.local 读取，不进入 server/env.ts 注册表。
# 每个 config.{instance}.json 对应一个企业微信智能表格目标，webhook URL 按实例独立注入。
#
# 企业微信智能表格 Webhook 申请路径：智能表格 → 自动化 → 新建 → Webhook 触发器。
# ⚠️ Webhook URL 含密钥（key=...），禁止提交到仓库。

# post-ETL 自动同步开关：1=启用（daily.mjs 结束时执行步骤 8），0=禁用（默认）
WECOM_SMARTSHEET_ENABLED=0

# 实例 webhook URL
# v2 实例（YAML 优先，与 instances/*.yaml 的 webhook_env 字段匹配）
WECOM_SMARTSHEET_WEBHOOK_SC_2025H1=
WECOM_SMARTSHEET_WEBHOOK_SC_2025H2=
# 12 个三级机构 2025-05~07 起期续保实例（与 instances/sichuan_<org>_2025_may_jul.yaml 的 webhook_env 字段匹配）
WECOM_SMARTSHEET_WEBHOOK_GAOXIN=
WECOM_SMARTSHEET_WEBHOOK_ZIGONG=
WECOM_SMARTSHEET_WEBHOOK_QINGYANG=
WECOM_SMARTSHEET_WEBHOOK_YIBIN=
WECOM_SMARTSHEET_WEBHOOK_TIANFU=
WECOM_SMARTSHEET_WEBHOOK_DAZHOU=
WECOM_SMARTSHEET_WEBHOOK_DEYANG=
WECOM_SMARTSHEET_WEBHOOK_WUHOU=
WECOM_SMARTSHEET_WEBHOOK_XINDU=
WECOM_SMARTSHEET_WEBHOOK_LUZHOU=
WECOM_SMARTSHEET_WEBHOOK_LESHAN=
WECOM_SMARTSHEET_WEBHOOK_ZIYANG=
# 邮政经代签单明细：全量表
WECOM_SMARTSHEET_WEBHOOK_POSTAL_ALL=
# 山西邮政/邮储经代签单全量表（branch_code='SX'）
WECOM_SMARTSHEET_WEBHOOK_SX_POSTAL=
# v1 旧 all_orgs 单实例（兼容旧 sync_renewal.py / config.*.json，可选）
WECOM_SMARTSHEET_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# 企业微信 HTML 报告推送
# 用于 数据管理/integrations/wecom_bot/push_html.py
# 路径：HTML → server/data/reports/ 托管（chexian-api /reports/:filename 路由）
#       → 公网 URL 写到智能表格 URL 字段 → 用户在企微 App 点击 → 浏览器渲染
# 复用 wecom-cli init 时配的机器人凭据。
# meta 文件存放在 数据管理/integrations/wecom_bot/state/
#   _html_push_meta.json     —— 推送目标智能表格 docid+sheet_id
#   _feedback_form_meta.json —— 反馈表 URL（嵌入到 HTML 模板底部）

# 公网 base URL：拼接报告链接写入智能表格的 URL 字段
# 本地开发：http://localhost:3000
# VPS 生产：https://chexian.cretvalu.com
PUBLIC_BASE_URL=http://localhost:3000
