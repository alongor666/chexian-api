# 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值
# ⚠️ .env.local 已被 .gitignore 忽略，不会提交到 Git

# ============================================================
# AI 提供商配置（支持多提供商 + 自动降级）
# ============================================================

# ------------------------------------------------------------
# 智谱 GLM（推荐 - 中文优化，性价比高）
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
# 格式：{id}.{secret}（32字符.24字符）
# 用于：AI SQL 生成
# ------------------------------------------------------------
VITE_ZHIPU_API_KEY=
VITE_ZHIPU_MODEL=glm-4.7-flashx

# ------------------------------------------------------------
# OpenRouter（机构趋势AI主路由）
# 获取地址：https://openrouter.ai/keys
# AI_PRIMARY_MODEL 支持多个模型逗号分隔，按顺序自动降级
# 示例：
# AI_PRIMARY_MODEL=minimax/minimax-m2.5,openai/gpt-4o-mini,bytedance-seed/seed-2.0-mini
# ------------------------------------------------------------
OPENROUTER_API_KEY=
AI_PRIMARY_MODEL=minimax/minimax-m2.5
# 单模型超时（毫秒，默认 4500）
AI_PROVIDER_TIMEOUT_MS=4500
# 机构趋势解读缓存时长（毫秒，默认 180000=3分钟）
AI_TREND_CACHE_TTL_MS=180000

# ============================================================
# 数据配置
# ============================================================

# 是否启用预加载数据
VITE_AUTO_LOAD_DATA=false

# 预加载数据的 URL 路径
VITE_DATA_URL=/data/data.parquet

# 应用标题
VITE_APP_TITLE=车险业绩分析系统

# 综合分析页开关（默认关闭，灰度开启）
VITE_ENABLE_COMPREHENSIVE_ANALYSIS=false

# ============================================================
# 后端查询模式
# ============================================================
# 系统固定为“全环境实时聚合”：
# - 所有分析查询实时基于 PolicyFact 行级数据执行
# - 不依赖 DailyAggregated / PeriodAggregated / EarnedPremiumMonthly 等预聚合表
