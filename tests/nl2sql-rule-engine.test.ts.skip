/**
 * NL2SQL 规则引擎单元测试
 */

import { describe, it, expect } from 'vitest';
import { convertNL2SQL, getExampleQueries, getAvailableRules } from '../src/features/sql-query/ruleEngine';
import { matchPatterns, getBestMatch } from '../src/features/sql-query/ruleEngine/patterns';

describe('NL2SQL 规则引擎', () => {
  describe('趋势分析规则', () => {
    it('应该匹配"最近30天的保费趋势"', () => {
      const result = convertNL2SQL('最近30天的保费趋势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('SELECT');
      expect(result.sql).toContain('policy_date');
      expect(result.sql).toContain('SUM(premium)');
      expect(result.sql).toContain('INTERVAL 30 DAY');
      expect(result.ruleId).toBe('trend-daily');
      expect(result.confidence).toBeGreaterThan(0.5);
    });

    it('应该匹配"最近7天的趋势"（默认保费指标）', () => {
      const result = convertNL2SQL('最近7天的趋势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('INTERVAL 7 DAY');
      expect(result.entities?.days).toBe(7);
    });

    it('应该匹配"最近12个月的保费趋势"', () => {
      const result = convertNL2SQL('最近12个月的保费趋势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain("DATE_TRUNC('month'");
      expect(result.sql).toContain('LIMIT 12');
      expect(result.ruleId).toBe('trend-monthly');
    });

    it('应该匹配"按月统计保费走势"', () => {
      const result = convertNL2SQL('按月统计保费走势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain("DATE_TRUNC('month'");
      expect(result.entities?.timeGranularity).toBe('month');
    });

    it('应该匹配"每日保单量趋势"', () => {
      const result = convertNL2SQL('每日保单量趋势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('COUNT(*)');
      expect(result.entities?.timeGranularity).toBe('day');
    });
  });

  describe('Top N 排名规则', () => {
    it('应该匹配"保费最高的10个业务员"', () => {
      const result = convertNL2SQL('保费最高的10个业务员');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('salesman_name');
      expect(result.sql).toContain('LIMIT 10');
      expect(result.ruleId).toBe('topn-salesmen');
    });

    it('应该匹配"Top 5 机构"', () => {
      const result = convertNL2SQL('Top 5 机构');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('org_name');
      expect(result.sql).toContain('LIMIT 5');
      expect(result.ruleId).toBe('topn-orgs');
    });

    it('应该匹配"业绩最好的20个业务员"', () => {
      const result = convertNL2SQL('业绩最好的20个业务员');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('LIMIT 20');
    });

    it('应该使用默认Top 10（未指定数量）', () => {
      const result = convertNL2SQL('保费最高的业务员');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('LIMIT 10');
      expect(result.entities?.limit).toBe(10);
    });
  });

  describe('占比分析规则', () => {
    it('应该匹配"按客户类别的保费占比"', () => {
      const result = convertNL2SQL('按客户类别的保费占比');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('customer_category');
      expect(result.sql).toContain('share_pct');
      expect(result.ruleId).toBe('ratio-customer-category');
    });

    it('应该匹配"险别分布"', () => {
      const result = convertNL2SQL('险别分布');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('coverage_combination');
      expect(result.ruleId).toBe('ratio-coverage');
    });

    it('应该匹配"按险种的占比"', () => {
      const result = convertNL2SQL('按险种的占比');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('coverage_combination');
    });
  });

  describe('对比分析规则', () => {
    it('应该匹配"电销与非电销对比"', () => {
      const result = convertNL2SQL('电销与非电销对比');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('is_telemarketing');
      expect(result.sql).toContain("CASE");
      expect(result.sql).toContain("'电销'");
      expect(result.ruleId).toBe('compare-telemarketing');
    });
  });

  describe('KPI 总览规则', () => {
    it('应该匹配"核心KPI总览"', () => {
      const result = convertNL2SQL('核心KPI总览');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('COUNT(*)');
      expect(result.sql).toContain('SUM(premium)');
      expect(result.sql).toContain('AVG(premium)');
      expect(result.sql).toContain('COUNT(DISTINCT salesman_name)');
      expect(result.ruleId).toBe('kpi-overview');
    });

    it('应该匹配"整体指标汇总"', () => {
      const result = convertNL2SQL('整体指标汇总');

      expect(result.success).toBe(true);
      expect(result.ruleId).toBe('kpi-overview');
    });
  });

  describe('边界情况和错误处理', () => {
    it('应该处理空输入', () => {
      const result = convertNL2SQL('');

      expect(result.success).toBe(false);
      expect(result.error).toContain('不能为空');
      expect(result.suggestions).toBeDefined();
      expect(result.suggestions!.length).toBeGreaterThan(0);
    });

    it('应该处理无法匹配的输入', () => {
      const result = convertNL2SQL('这是一个完全无法识别的查询');

      expect(result.success).toBe(false);
      expect(result.error).toBeDefined();
      expect(result.suggestions).toBeDefined();
    });

    it('应该返回智能建议（包含"趋势"关键词）', () => {
      const result = convertNL2SQL('趋势abc');

      if (!result.success && result.suggestions) {
        expect(result.suggestions.some((s) => s.includes('趋势'))).toBe(true);
      }
    });

    it('应该返回智能建议（包含"排名"关键词）', () => {
      const result = convertNL2SQL('排名xyz');

      if (!result.success && result.suggestions) {
        expect(result.suggestions.some((s) => s.includes('Top') || s.includes('排名'))).toBe(true);
      }
    });

    it('应该返回智能建议（包含"占比"关键词）', () => {
      const result = convertNL2SQL('占比123');

      if (!result.success && result.suggestions) {
        expect(result.suggestions.some((s) => s.includes('占比'))).toBe(true);
      }
    });
  });

  describe('置信度和多规则匹配', () => {
    it('应该返回所有匹配结果（returnAllMatches=true）', () => {
      const result = convertNL2SQL('最近30天的保费趋势', {
        returnAllMatches: true,
      });

      expect(result.success).toBe(true);
      expect(result.allMatches).toBeDefined();
      expect(result.allMatches!.length).toBeGreaterThan(0);
    });

    it('应该按置信度降序排序', () => {
      const matches = matchPatterns('最近30天的保费趋势');

      if (matches.length > 1) {
        for (let i = 0; i < matches.length - 1; i++) {
          expect(matches[i].confidence).toBeGreaterThanOrEqual(matches[i + 1].confidence);
        }
      }
    });

    it('应该返回最佳匹配', () => {
      const bestMatch = getBestMatch('保费最高的10个业务员');

      expect(bestMatch).not.toBeNull();
      expect(bestMatch!.ruleId).toBe('topn-salesmen');
    });

    it('应该支持置信度阈值', () => {
      const result = convertNL2SQL('某个模糊的查询', {
        minConfidence: 0.9,
      });

      if (!result.success) {
        expect(result.error).toBeDefined();
      }
    });
  });

  describe('SQL 安全验证', () => {
    it('生成的SQL应该通过安全验证', () => {
      const result = convertNL2SQL('最近30天的保费趋势', {
        validateSafety: true,
      });

      expect(result.success).toBe(true);
      expect(result.sql).not.toContain('DROP');
      expect(result.sql).not.toContain('DELETE');
      expect(result.sql).not.toContain('UPDATE');
      expect(result.sql).not.toContain('INSERT');
    });

    it('应该禁用SQL验证（validateSafety=false）', () => {
      const result = convertNL2SQL('最近30天的保费趋势', {
        validateSafety: false,
      });

      expect(result.success).toBe(true);
    });
  });

  describe('辅助函数', () => {
    it('应该返回所有可用规则', () => {
      const rules = getAvailableRules();

      expect(rules.length).toBeGreaterThan(0);
      expect(rules[0]).toHaveProperty('id');
      expect(rules[0]).toHaveProperty('name');
    });

    it('应该返回示例查询列表', () => {
      const examples = getExampleQueries();

      expect(examples.length).toBeGreaterThan(0);
      expect(examples[0]).toHaveProperty('category');
      expect(examples[0]).toHaveProperty('examples');
      expect(examples[0].examples.length).toBeGreaterThan(0);
    });

    it('示例查询应该全部可以成功转换', () => {
      const examples = getExampleQueries();

      examples.forEach((categoryGroup) => {
        categoryGroup.examples.forEach((example) => {
          const result = convertNL2SQL(example);
          expect(result.success).toBe(true);
        });
      });
    });
  });

  describe('实体提取', () => {
    it('应该正确提取天数', () => {
      const result = convertNL2SQL('最近15天的保费趋势');

      expect(result.entities?.days).toBe(15);
    });

    it('应该正确提取限制数量', () => {
      const result = convertNL2SQL('Top 8 业务员');

      expect(result.entities?.limit).toBe(8);
    });

    it('应该正确提取时间粒度', () => {
      const result = convertNL2SQL('按周统计保费趋势');

      expect(result.entities?.timeGranularity).toBe('week');
    });

    it('应该正确提取指标（保单数）', () => {
      const result = convertNL2SQL('最近30天的保单数趋势');

      expect(result.entities?.metric).toContain('COUNT(*)');
    });

    it('应该正确提取维度（业务员）', () => {
      const result = convertNL2SQL('保费最高的业务员');

      expect(result.entities?.dimension).toBe('salesman_name');
    });
  });

  describe('复杂查询场景', () => {
    it('应该处理包含多个关键词的查询', () => {
      const result = convertNL2SQL('最近60天每日保费趋势');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('60');
      expect(result.sql).toContain('SUM(premium)');
    });

    it('应该处理英文关键词（Top）', () => {
      const result = convertNL2SQL('TOP10机构');

      expect(result.success).toBe(true);
      expect(result.sql).toContain('LIMIT 10');
    });

    it('应该处理不同的表达方式（最高/最多/最好）', () => {
      const inputs = [
        '保费最高的10个业务员',
        '保费最多的10个业务员',
        '业绩最好的10个业务员',
      ];

      inputs.forEach((input) => {
        const result = convertNL2SQL(input);
        expect(result.success).toBe(true);
        expect(result.sql).toContain('salesman_name');
      });
    });
  });
});
