{
  "$schema": "./schema.json",
  "_doc": "维修资源域 (RepairDim) + 理赔明细新增字段 — 不参与 PolicyFact 的 normalize/mapping codegen。仅作为字段注册表的第二事实源，用于文档和 governance 校验。消费方：server/src/sql/repair.ts + convert_repair.py + convert_claims_detail.py",
  "_related_codegen": "无（fields.json codegen 跳过此文件）",
  "_related_docs": [
    ".claude/shared-memory/repair_source_field_mapping.md",
    "数据管理/knowledge/rules/车险数据业务规则字典.md#维修资源分析口径"
  ],
  "domains": [
    {
      "domain": "repair",
      "source": "07_维修资源*.xlsx",
      "etl": "数据管理/pipelines/convert_repair.py",
      "output": "warehouse/dim/repair/latest.parquet",
      "duckdbRelation": "RepairDim (TABLE)",
      "fields": [
        {
          "id": "report_date",
          "label": "统计时间",
          "sourceColumn": "统计时间",
          "required": false,
          "dataTypes": ["DATE", "TIMESTAMP"],
          "description": "当天快照日期"
        },
        {
          "id": "org_level_3",
          "label": "修理厂归属中支",
          "sourceColumn": "修理厂归属中支",
          "required": false,
          "dataTypes": ["VARCHAR"],
          "description": "三级机构（与 PolicyFact.org_level_3 语义一致）"
        },
        {
          "id": "cooperation_status",
          "label": "当天合作状态",
          "sourceColumn": "当天合作状态",
          "required": true,
          "dataTypes": ["VARCHAR"],
          "description": "7 态枚举：1生效中/0暂停合作/3退回修改/5待复核/7已撤销/8失效/无合作",
          "enumValues": ["1生效中", "0暂停合作", "3退回修改", "5待复核", "7已撤销", "8失效", "无合作"],
          "derived": {
            "coop_tier": "CASE WHEN cooperation_status='1生效中' THEN 'active' WHEN cooperation_status IN ('0暂停合作','7已撤销','8失效') THEN 'past' ELSE 'none' END"
          }
        },
        {
          "id": "channel_type",
          "label": "渠道类型",
          "sourceColumn": "渠道类型",
          "required": false,
          "dataTypes": ["VARCHAR"]
        },
        {
          "id": "repair_shop_name",
          "label": "修理厂名称",
          "sourceColumn": "修理厂名称",
          "required": true,
          "dataTypes": ["VARCHAR"],
          "description": "格式：前 8 位=编码 + 中文名",
          "derived": {
            "shop_code": "SUBSTR(repair_shop_name, 1, 8)"
          }
        },
        {
          "id": "is_4s_shop",
          "label": "是否4S店",
          "sourceColumn": "是否4S店",
          "required": false,
          "dataTypes": ["BOOLEAN"]
        },
        {
          "id": "province",
          "label": "修理厂所在省",
          "sourceColumn": "修理厂所在省",
          "required": false,
          "dataTypes": ["VARCHAR"]
        },
        {
          "id": "city",
          "label": "修理厂所在市",
          "sourceColumn": "修理厂所在市",
          "required": false,
          "dataTypes": ["VARCHAR"]
        },
        {
          "id": "district",
          "label": "修理厂所在区",
          "sourceColumn": "修理厂所在区",
          "required": false,
          "dataTypes": ["VARCHAR"],
          "description": "散点图 X 轴维度"
        },
        {
          "id": "damage_assessment_amount",
          "label": "核损金额",
          "sourceColumn": "核损金额",
          "required": false,
          "dataTypes": ["DOUBLE"],
          "description": "= 维修产值（业务口径，用于修保比计算）"
        },
        {
          "id": "parts_discount_rate",
          "label": "换件折扣率",
          "sourceColumn": "换件折扣率",
          "required": false,
          "dataTypes": ["DOUBLE"],
          "description": "0-1 区间"
        },
        {
          "id": "net_premium",
          "label": "签单净保费",
          "sourceColumn": "签单净保费",
          "required": false,
          "dataTypes": ["DOUBLE"]
        }
      ],
      "exclusionRules": {
        "non_repair_keywords": ["定损", "自选"],
        "exact_exclude": ["无"],
        "description": "过滤非维修单位，JOIN 前须先剔除"
      }
    },
    {
      "domain": "claims_detail_repair_extension",
      "source": "02_理赔明细*.xlsx（v2 新增列）",
      "etl": "数据管理/pipelines/convert_claims_detail.py",
      "output": "warehouse/fact/claims_detail/latest.parquet",
      "duckdbRelation": "ClaimsDetail (VIEW)",
      "fields": [
        {
          "id": "subject_repair_shop",
          "label": "标的汽修厂",
          "sourceColumn": "标的汽修厂",
          "required": false,
          "dataTypes": ["VARCHAR"],
          "description": "标的车送修网点（与 third_party_repair 区分：后者为三者汽修厂）",
          "derived": {
            "subject_shop_code": "SUBSTR(subject_repair_shop, 1, 8)"
          }
        }
      ]
    }
  ]
}
