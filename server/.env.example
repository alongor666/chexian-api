# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=24h

# CORS配置（前端域名）
CORS_ORIGIN=http://localhost:5173

# DuckDB数据库路径
DUKEDB_PATH=:memory:

# Parquet数据文件路径
DATA_PATH=./data

# 日志级别
LOG_LEVEL=info

# AI API Keys
OPENROUTER_API_KEY=your-api-key
AI_PRIMARY_MODEL=google/gemini-flash-1.5-8b
ZHIPU_API_KEY=your-api-key

# 账号密码覆盖 (JSON 格式)
# 格式: USER_PASSWORDS='{"username": "bcrypt-hash", ...}'
# 注意: 在 .env 中使用单引号包裹 JSON 字符串，并转义 $ 符号（或在某些 shell 环境下使用 \$）
USER_PASSWORDS='{"admin":"$2b$10$..."}'
