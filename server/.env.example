# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS配置（前端域名）
CORS_ORIGIN=http://localhost:5173

# DuckDB数据库路径
DUCKDB_PATH=:memory:
# 生产环境使用：DUCKDB_PATH=./data/chexian.duckdb

# Parquet数据文件路径
DATA_PATH=./data

# 日志级别
LOG_LEVEL=info

# 开发环境跳过密码验证（仅 NODE_ENV!=production 时生效，任意密码均可登录）
# DEV_SKIP_AUTH=1
