#!/bin/bash
# post-checkout hook：
#   1. 转交 git-lfs（如果安装）
#   2. 缺依赖自动 bun install 子项目（解决 worktree add 后子 package 空 node_modules 陷阱）
#   3. server 原生模块自愈（CN 代理偶发腐蚀预编译下载 → 损坏 .node，从源码重编译兜底）
#
# Git 触发参数：
#   $1 = previous HEAD
#   $2 = new HEAD
#   $3 = checkout type (1=branch checkout，含 git worktree add；0=file checkout)
#
# 设计要点：
#   - 只在 branch checkout 时跑（$3=1），跳过 file checkout 避免不必要的扫描
#   - 只在子项目缺 node_modules 时跑 install — 普通切分支 0 开销
#   - 单个失败不阻断（warn 后继续），用户切分支不应被半夜的 npm registry 挂掉卡住
#   - 原生模块自愈仅在"本 hook 已触发安装"（worktree 新建 / 缺依赖）后运行，普通切分支 0 开销

# ── 1. git-lfs（保留现有行为）────────────────────────────────────
if command -v git-lfs >/dev/null 2>&1; then
  git lfs post-checkout "$@"
else
  printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, set core.hooksPath back to .git/hooks and remove this hook."
fi

# ── 2. 子项目依赖自愈 ───────────────────────────────────────────
# 仅在分支切换（含 git worktree add）时触发
[ "$3" != "1" ] && exit 0

ROOT="$(git rev-parse --show-toplevel)" || exit 0

# ── 2.0 worktree 重锚提示（cwd 漂移根治，见 .claude/rules/worktree-setup.md §A）──
# 仅在「链接 worktree」里提示：主 checkout 的 git-dir == git-common-dir，链接 worktree 二者不同 → 不打扰主目录普通切分支。
# git hook 无法替会话调用 harness 的 EnterWorktree，只能提醒（warn-only）；漏调会导致 cwd 回弹主目录、相对路径全落主目录。
if [ "$(git rev-parse --git-dir 2>/dev/null)" != "$(git rev-parse --git-common-dir 2>/dev/null)" ]; then
  printf >&2 "\n%s\n%s\n\n" \
    "💡 [post-checkout] 已进入 worktree：$ROOT" \
    "   若在已有会话中创建（会话仍锚在原目录），请调用 EnterWorktree({path: \"$ROOT\"}) 重锚，否则 cwd 回弹主目录、编辑易漏进 main（详见 .claude/rules/worktree-setup.md §A「cwd 漂移根治」）。"
fi

# 子项目清单：root workspace (cli/mcp 由 root bun install 联动) + server 独立 package
SUBPACKAGES=("cli" "mcp" "server")

NEED_INSTALL=()
for SUB in "${SUBPACKAGES[@]}"; do
  if [ -f "$ROOT/$SUB/package.json" ] && [ ! -d "$ROOT/$SUB/node_modules" ]; then
    NEED_INSTALL+=("$SUB")
  fi
done

ROOT_NEEDS=""
if [ -f "$ROOT/package.json" ] && [ ! -d "$ROOT/node_modules" ]; then
  ROOT_NEEDS="root"
fi

if [ -z "$ROOT_NEEDS" ] && [ ${#NEED_INSTALL[@]} -eq 0 ]; then
  exit 0
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "⚠️  [post-checkout] bun 未安装，跳过子项目依赖自愈（请手动 bun install）"
  exit 0
fi

if [ -n "$ROOT_NEEDS" ]; then
  echo "🔧 [post-checkout] root 缺 node_modules，自动 bun install（含 workspaces cli/mcp）..."
  if bun install --cwd "$ROOT" >/dev/null 2>&1; then
    echo "✅ [post-checkout] root bun install 完成"
  else
    echo "⚠️  [post-checkout] root bun install 失败，请手动重试: bun install"
  fi
  # root install 后 workspaces (cli, mcp) 已就位，从 NEED_INSTALL 移除
  NEED_INSTALL=("${NEED_INSTALL[@]/cli}")
  NEED_INSTALL=("${NEED_INSTALL[@]/mcp}")
fi

for SUB in "${NEED_INSTALL[@]}"; do
  [ -z "$SUB" ] && continue
  echo "🔧 [post-checkout] $SUB 缺 node_modules，自动 bun install..."
  if bun install --cwd "$ROOT/$SUB" >/dev/null 2>&1; then
    echo "✅ [post-checkout] $SUB bun install 完成"
  else
    echo "⚠️  [post-checkout] $SUB bun install 失败，请手动重试: bun install --cwd $ROOT/$SUB"
  fi
done

# ── 3. server 原生模块自愈 ──────────────────────────────────────
# 背景：CN 代理（如 127.0.0.1:1082）偶发腐蚀预编译二进制下载（node-pre-gyp / optional
#       平台包）。install 会报"完成"，但 .node 被截断，dlopen 崩
#       （"segment '__LINKEDIT' ... extends beyond end of file"）→ 所有走 auth/permission
#       链路的 server 测试在 *加载阶段* 整套失败，pre-push 的 bun run test 跑不过。
# 策略：逐个原生模块做 require 健康检查（判退出码，禁用管道以免吞掉真实退出码），
#       对加载失败者按模块**分发类型**选不同自愈命令（统一逻辑会对 @duckdb 失效）：
#         · 源码可编译型（bcrypt / better-sqlite3）：有 C++ 源码 →
#           `rm 模块 + npm_config_build_from_source=true bun install` 从源码重编译，
#           绕开被腐蚀的预编译下载（源码已在 node_modules，仅需本机 clang，不改 lockfile）。
#         · 纯预编译分发型（@duckdb/node-api）：facade 包 scripts 为空，无源码可编译；真正
#           的 .node 在 optional 平台包 @duckdb/node-bindings-<platform> 里（macOS 是
#           node-bindings-darwin-arm64）。只删 facade（node-api）时 bun 仍见 bindings 目录
#           认为已装、不重拉 → 必须删**整个 @duckdb scope** 再 bun install 才会重拉 bindings；
#           且 build-from-source 对它无意义（无 C++ 源码）。
# 范围：仅在已执行过安装（上方未提前 exit）时运行 → 普通切分支 0 开销。
#       健康时跳过；自愈失败时打印手动指引但不阻断 checkout（warn-only）。
SERVER_DIR="$ROOT/server"
if command -v node >/dev/null 2>&1 && [ -d "$SERVER_DIR/node_modules" ]; then
  NATIVE_MODULES=("bcrypt" "better-sqlite3" "@duckdb/node-api")
  for M in "${NATIVE_MODULES[@]}"; do
    [ -d "$SERVER_DIR/node_modules/$M" ] || continue
    if ( cd "$SERVER_DIR" && node -e "require('$M')" ) >/dev/null 2>&1; then
      continue  # 健康，跳过
    fi
    # 按分发类型选自愈命令：纯预编译型删整个 scope 重拉 bindings；源码型从源码重编译
    case "$M" in
      @duckdb/*)
        RM_TARGET="node_modules/@duckdb"   # 删整个 scope，否则 bun 不重拉 bindings 平台包
        BUILD_ENV=""                       # 纯预编译分发，无源码可 build-from-source
        HEAL_DESC="重拉预编译 bindings"
        ;;
      *)
        RM_TARGET="node_modules/$M"
        BUILD_ENV="npm_config_build_from_source=true"
        HEAL_DESC="从源码重编译"
        ;;
    esac
    MANUAL_HINT="(cd server && rm -rf $RM_TARGET && ${BUILD_ENV:+$BUILD_ENV }bun install)"
    echo "🔧 [post-checkout] $M 原生二进制损坏（疑似代理腐蚀下载），$HEAL_DESC..."
    # 用 env 注入可选环境变量：变量经展开后不会被识别为前缀赋值，必须借 env 生效（BUILD_ENV 空时 env 直接跑 bun install）
    if ( cd "$SERVER_DIR" && rm -rf "$RM_TARGET" && env $BUILD_ENV bun install ) >/dev/null 2>&1 \
       && ( cd "$SERVER_DIR" && node -e "require('$M')" ) >/dev/null 2>&1; then
      echo "✅ [post-checkout] $M 已$HEAL_DESC恢复"
    else
      echo "⚠️  [post-checkout] $M 自愈失败，请手动: $MANUAL_HINT"
    fi
  done
fi

exit 0
