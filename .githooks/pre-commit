#!/usr/bin/env bash
set -euo pipefail

echo "[pre-commit] Cleaning untracked debug artifacts..."
bun run cleanup:artifacts

echo "[pre-commit] Running governance checks..."
bun run governance

echo "[pre-commit] Running test preflight..."
bun run test:preflight -- --mode unit

echo "[pre-commit] Running core regression tests..."
bun run test -- --run \
  tests/api/client.test.ts \
  tests/api/client-contracts.test.ts \
  tests/api/wecom-mapping-path.test.ts \
  tests/comparison-presets.test.ts \
  tests/shared/types/branded.test.ts
