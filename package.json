{
  "name": "chexian-api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "cli",
    "mcp"
  ],
  "scripts": {
    "start": "node scripts/start.mjs",
    "start:dev": "node scripts/start.mjs --dev",
    "start:server": "node scripts/start.mjs --server",
    "dev": "vite",
    "dev:full": "node scripts/start.mjs --all",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "build:analyze": "NODE_OPTIONS='--max-old-space-size=4096' vite build --mode analyze",
    "typecheck": "node scripts/typecheck.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:preflight": "node scripts/test-preflight.mjs",
    "test:py": "python3 -m pytest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:cleanup-gate": "playwright test tests/e2e/03-cleanup-zero-downtime-gate.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "cleanup:artifacts": "node scripts/cleanup-debug-artifacts.mjs",
    "test:burn-down": "node scripts/test-burn-down.mjs",
    "verify:vps:heatmap": "node scripts/verify-vps-heatmap.mjs",
    "verify:agent:smoke": "bun scripts/verify-agent-production-smoke.mjs",
    "reports:manifest": "node scripts/gen-reports-manifest.mjs",
    "release:daily": "node scripts/sync-and-reload.mjs --wecom",
    "release:daily:check": "node scripts/sync-and-reload.mjs --wecom-dry-run",
    "pull:bi": "node scripts/pull-bi-exports.mjs",
    "auto-release:install": "node scripts/auto-release-daily.mjs --install-launchd",
    "auto-release:status": "node scripts/auto-release-daily.mjs --status",
    "auto-release:once": "node scripts/auto-release-daily.mjs --once",
    "ledger:analyze": "node scripts/etl-ledger/analyze.mjs",
    "release:daily:dry": "node scripts/sync-and-reload.mjs --wecom-dry-run --dry-run",
    "daily:doctor": "node scripts/daily-doctor.mjs",
    "release:vps:heatmap": "node scripts/release-vps-heatmap.mjs",
    "benchmark:key-routes": "node scripts/benchmark-key-routes.mjs",
    "benchmark:key-routes:soak": "node scripts/benchmark-key-routes-soak.mjs",
    "test:all": "bun run typecheck && bun run build && bun run test --run && bun run test:e2e tests/e2e/04-subpage-no-refresh.spec.ts",
    "check:chunks": "node scripts/check-chunk-invariants.mjs",
    "governance": "node scripts/check-governance.mjs && node scripts/check-permission-coverage.mjs && bun run governance:harness",
    "governance:harness": "node scripts/governance/harness.mjs",
    "governance:hotfiles": "node scripts/check-hotfile-contracts.mjs",
    "governance:permissions": "node scripts/check-permission-coverage.mjs",
    "lint:ui": "node scripts/lint-ui.mjs",
    "deploy:check": "node scripts/check-deploy-readiness.mjs",
    "deploy:check:health": "node scripts/check-deploy-readiness.mjs --require-health",
    "plans:manage": "node scripts/manage-plans.mjs",
    "backlog:render": "bun scripts/governance-backlog-curate.mjs --apply",
    "loop:dispatch": "node scripts/loop/dispatch.mjs",
    "loop:quality": "node scripts/loop/quality-report.mjs",
    "loop:automation-due": "node scripts/loop/automation-due.mjs",
    "loop:stale-scan": "node scripts/loop/stale-scan.mjs",
    "loop:rule-hit-rate": "node scripts/loop/rule-hit-rate.mjs",
    "loop:pattern-watch": "node scripts/loop/rule-hit-rate.mjs --watch",
    "verify:quick": "node scripts/test-preflight.mjs && bun run governance && bun run typecheck",
    "verify:full": "bun run verify:quick && bun run test --run",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "test:integration": "vitest --run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.4.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.562.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "react-window": "^1.8.11",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  },
  "overrides": {
    "dompurify": ">=3.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.5.2",
    "jsdom": "^27.4.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^3.2.7"
  }
}
