  "keywords": {
    "天然气": {
      "where": "fuel_type = '天然气(NG/CNG/LNG)'",
      "category": "燃料",
      "note": "fuel_type 在 2025 有 71% 覆盖率（29% 空值），目标段内通常无空"
    },
    "汽油": {"where": "fuel_type = '汽油'", "category": "燃料"},
    "柴油": {"where": "fuel_type = '柴油'", "category": "燃料"},
    "纯电动": {
      "where": "fuel_type IN ('纯电动(精友)', '纯电动(行业)')",
      "category": "燃料",
      "note": "合并精友和行业两个来源"
    },
    "插电混动": {
      "where": "fuel_type IN ('插电式混合动力(精友)', '插电式混合动力(行业)')",
      "category": "燃料"
    },
    "新能源": {
      "where": "is_nev = TRUE",
      "category": "燃料",
      "note": "新能源标识字段，包括 BEV/PHEV/HEV/REEV 等"
    },
    "两用燃料": {"where": "fuel_type = '两用燃料'", "category": "燃料"},
    "10吨以上": {"where": "tonnage_segment = '10吨以上'", "category": "吨位"},
    "9-10吨": {"where": "tonnage_segment = '9-10吨'", "category": "吨位"},
    "2-9吨": {"where": "tonnage_segment = '2-9吨'", "category": "吨位"},
    "1-2吨": {"where": "tonnage_segment = '1-2吨'", "category": "吨位"},
    "1吨以下": {"where": "tonnage_segment = '1吨以下'", "category": "吨位"},
    "大货车": {
      "where": "tonnage_segment IN ('9-10吨', '10吨以上')",
      "category": "吨位",
      "note": "9 吨以上营业货车的通用聚合口径"
    },
    "牵引车": {
      "where": "truck_type = '牵引'",
      "category": "货车类型",
      "note": "用 truck_type 枚举等值查询（含半挂牵引/危险品牵引/天然气牵引等），与 vehicle_model LIKE '%牵引%' 在 2025 完全等价"
    },
    "自卸车": {"where": "truck_type = '自卸（非垃圾）'", "category": "货车类型"},
    "厢式货车": {"where": "truck_type = '厢式'", "category": "货车类型"},
